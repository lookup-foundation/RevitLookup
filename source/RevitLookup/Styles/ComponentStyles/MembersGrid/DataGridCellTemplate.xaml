<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:decomposition="clr-namespace:RevitLookup.Abstractions.ObservableModels.Decomposition;assembly=RevitLookup.Abstractions"
    xmlns:ui="http://lookupengine.com/xaml"
    xmlns:converters="clr-namespace:RevitLookup.UI.Framework.Converters;assembly=RevitLookup.UI.Framework"
    xmlns:views="clr-namespace:RevitLookup.UI.Framework.Views.Decomposition;assembly=RevitLookup.UI.Framework"
    xmlns:lookupConverters="clr-namespace:RevitLookup.Styles.Converters"
    mc:Ignorable="d">

    <DataTemplate
        x:Key="DefaultSummaryCellTemplate"
        DataType="{x:Type decomposition:ObservableDecomposedMember}">
        <ui:TextBlock
            VerticalAlignment="Center"
            FontTypography="Caption"
            FontWeight="{Binding FontWeight,
                RelativeSource={RelativeSource FindAncestor, AncestorType=DataGridRow}}"
            Text="{Binding .,
                Converter={x:Static converters:DescriptorFormattingConverters.MemberDisplayText},
                Mode=OneTime}" />
    </DataTemplate>

    <DataTemplate
        x:Key="InvalidSummaryCellTemplate"
        DataType="{x:Type decomposition:ObservableDecomposedMember}">
        <StackPanel
            Orientation="Horizontal"
            ToolTip="The member value is an empty string">
            <ui:SymbolIcon
                FontSize="16"
                VerticalAlignment="Center"
                Symbol="CodeTextOff16" />
            <ui:TextBlock
                Margin="4 0 0 0"
                VerticalAlignment="Center"
                FontTypography="Caption"
                FontWeight="{Binding FontWeight,
                    RelativeSource={RelativeSource FindAncestor, AncestorType=DataGridRow}}"
                Text="Empty string" />
        </StackPanel>
    </DataTemplate>

    <DataTemplate
        x:Key="NullSummaryCellTemplate"
        DataType="{x:Type decomposition:ObservableDecomposedMember}">
        <StackPanel
            Orientation="Horizontal"
            ToolTip="The member value is null">
            <ui:SymbolIcon
                FontSize="16"
                VerticalAlignment="Center"
                Symbol="CircleOff16" />
            <ui:TextBlock
                Margin="4 0 0 0"
                VerticalAlignment="Center"
                FontTypography="Caption"
                FontWeight="{Binding FontWeight,
                    RelativeSource={RelativeSource FindAncestor, AncestorType=DataGridRow}}"
                Text="Null reference" />
        </StackPanel>
    </DataTemplate>

    <DataTemplate
        x:Key="SummaryMediaColorCellTemplate"
        DataType="{x:Type decomposition:ObservableDecomposedMember}">
        <StackPanel
            Orientation="Horizontal">
            <ui:TextBlock
                VerticalAlignment="Center"
                FontTypography="Caption"
                FontWeight="{Binding FontWeight,
                    RelativeSource={RelativeSource FindAncestor, AncestorType=DataGridRow}}"
                Text="{Binding .,
                    Converter={x:Static converters:DescriptorFormattingConverters.MemberDisplayText},
                    Mode=OneTime}" />
            <Border
                CornerRadius="4"
                Padding="4 2"
                Margin="4 0 0 0"
                VerticalAlignment="Center"
                d:DataContext="{d:DesignInstance decomposition:ObservableDecomposedMember}">
                <Border.Background>
                    <SolidColorBrush
                        Opacity="0.05"
                        Color="{DynamicResource FocusStrokeColorOuter}" />
                </Border.Background>
                <Border
                    Width="10"
                    Height="10">
                    <Border.Background>
                        <SolidColorBrush
                            Color="{Binding Value.RawValue,
                            Converter={x:Static lookupConverters:ColorConverters.MediaColor},
                            Mode=OneTime}" />
                    </Border.Background>
                </Border>
            </Border>
        </StackPanel>
    </DataTemplate>

    <DataTemplate
        x:Key="DeferredSummaryCellTemplate"
        DataType="{x:Type decomposition:ObservableDecomposedMember}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel
                Grid.Column="0"
                Orientation="Horizontal"
                ToolTip="The member is not evaluated yet">
                <ui:SymbolIcon
                    FontSize="16"
                    VerticalAlignment="Center"
                    Symbol="Clock16"
                    Foreground="{DynamicResource SystemFillColorAttentionBrush}" />
                <ui:TextBlock
                    Margin="4 0 0 0"
                    VerticalAlignment="Center"
                    FontTypography="Caption"
                    FontWeight="{Binding FontWeight,
                        RelativeSource={RelativeSource FindAncestor, AncestorType=DataGridRow}}"
                    Text="Awaiting" />
            </StackPanel>
            <ui:Button
                x:Name="EvaluateButton"
                Grid.Column="1"
                Margin="8 0 0 0"
                Padding="6 2"
                VerticalAlignment="Center"
                Cursor="Hand"
                Appearance="Transparent"
                Visibility="Collapsed"
                Command="{Binding ViewModel.ForceEvaluateMemberCommand,
                    RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type views:SummaryViewBase}}}"
                CommandParameter="{Binding}">
                <StackPanel
                    Orientation="Horizontal">
                    <ui:SymbolIcon
                        FontSize="14"
                        Symbol="Calculator16"
                        VerticalAlignment="Center" />
                    <ui:TextBlock
                        Margin="4 0 0 0"
                        VerticalAlignment="Center"
                        FontTypography="Caption"
                        Text="Evaluate" />
                </StackPanel>
            </ui:Button>
        </Grid>
        <DataTemplate.Triggers>
            <DataTrigger
                Binding="{Binding IsMouseOver, RelativeSource={RelativeSource FindAncestor, AncestorType=DataGridRow}}"
                Value="True">
                <Setter
                    TargetName="EvaluateButton"
                    Property="Visibility"
                    Value="Visible" />
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <DataTemplate
        x:Key="DisabledSummaryCellTemplate"
        DataType="{x:Type decomposition:ObservableDecomposedMember}">
        <StackPanel
            Orientation="Horizontal"
            ToolTip="Member evaluation permanently disabled">
            <ui:SymbolIcon
                FontSize="16"
                VerticalAlignment="Center"
                Symbol="LockClosed16"
                Foreground="{DynamicResource SystemFillColorCautionBrush}" />
            <ui:TextBlock
                Margin="4 0 0 0"
                VerticalAlignment="Center"
                FontTypography="Caption"
                FontWeight="{Binding FontWeight,
                    RelativeSource={RelativeSource FindAncestor, AncestorType=DataGridRow}}"
                Text="Disabled" />
        </StackPanel>
    </DataTemplate>

    <DataTemplate
        x:Key="UnsupportedSummaryCellTemplate"
        DataType="{x:Type decomposition:ObservableDecomposedMember}">
        <StackPanel
            Orientation="Horizontal"
            ToolTip="Member evaluation not supported by the engine">
            <ui:SymbolIcon
                FontSize="16"
                VerticalAlignment="Center"
                Symbol="Prohibited16" />
            <ui:TextBlock
                Margin="4 0 0 0"
                VerticalAlignment="Center"
                FontTypography="Caption"
                FontWeight="{Binding FontWeight,
                    RelativeSource={RelativeSource FindAncestor, AncestorType=DataGridRow}}"
                Text="Unsupported" />
        </StackPanel>
    </DataTemplate>

    <DataTemplate
        x:Key="ExceptionSummaryCellTemplate"
        DataType="{x:Type decomposition:ObservableDecomposedMember}">
        <StackPanel
            Orientation="Horizontal">
            <ui:SymbolIcon
                FontSize="16"
                VerticalAlignment="Center"
                Symbol="ErrorCircle16"
                Foreground="{DynamicResource SystemFillColorCriticalBrush}" />
            <ui:TextBlock
                Margin="4 0 0 0"
                VerticalAlignment="Center"
                FontTypography="Caption"
                TextTrimming="CharacterEllipsis"
                FontWeight="{Binding FontWeight,
                    RelativeSource={RelativeSource FindAncestor, AncestorType=DataGridRow}}"
                Text="{Binding .,
                    Converter={x:Static converters:DescriptorFormattingConverters.MemberDisplayText},
                    Mode=OneTime}" />
        </StackPanel>
    </DataTemplate>

</ResourceDictionary>