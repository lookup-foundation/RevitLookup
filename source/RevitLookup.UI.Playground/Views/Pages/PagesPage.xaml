<Page
    x:Class="RevitLookup.UI.Playground.Views.Pages.PagesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:pages="clr-namespace:RevitLookup.UI.Playground.Views.Pages"
    xmlns:ui="http://lookupengine.com/xaml"
    mc:Ignorable="d"
    d:DesignHeight="500"
    d:DesignWidth="500"
    d:DataContext="{d:DesignInstance pages:PagesPage}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <StackPanel
        Margin="0 24">

        <ui:TextBlock
            Text="Navigation elements"
            FontTypography="BodyStrong" />
        <ui:TextBlock
            Margin="0 2 0 0"
            Text="Pages hosted inside the main window."
            FontTypography="Caption"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        <ui:CardAction
            Margin="0 8 0 0"
            Icon="{ui:SymbolIcon AppGeneric24}"
            Command="{Binding ViewModel.ShowDashboardPageCommand}">
            <StackPanel>
                <ui:TextBlock Text="Dashboard page" FontTypography="BodyStrong" />
                <ui:TextBlock
                    Text="The landing page with shortcuts to inspectable objects."
                    FontTypography="Caption"
                    TextWrapping="Wrap"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </ui:CardAction>
        <ui:CardAction
            Margin="0 4 0 0"
            Icon="{ui:SymbolIcon SlideSearch24}"
            Command="{Binding ViewModel.ShowDecompositionSummaryPageCommand}">
            <StackPanel>
                <ui:TextBlock Text="Decomposition summary page" FontTypography="BodyStrong" />
                <ui:TextBlock
                    Text="The object and member grid for a decomposition result."
                    FontTypography="Caption"
                    TextWrapping="Wrap"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </ui:CardAction>
        <ui:CardAction
            Margin="0 4 0 0"
            Icon="{ui:SymbolIcon DesktopPulse24}"
            Command="{Binding ViewModel.ShowEventsSummaryPageCommand}">
            <StackPanel>
                <ui:TextBlock Text="Events summary page" FontTypography="BodyStrong" />
                <ui:TextBlock
                    Text="The live list of captured events."
                    FontTypography="Caption"
                    TextWrapping="Wrap"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </ui:CardAction>
        <ui:CardAction
            Margin="0 4 0 0"
            Icon="{ui:SymbolIcon Settings24}"
            Command="{Binding ViewModel.ShowSettingsPageCommand}">
            <StackPanel>
                <ui:TextBlock Text="Settings page" FontTypography="BodyStrong" />
                <ui:TextBlock
                    Text="Application preferences like theme and rendering."
                    FontTypography="Caption"
                    TextWrapping="Wrap"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </ui:CardAction>
        <ui:CardAction
            Margin="0 4 0 0"
            Icon="{ui:SymbolIcon Info24}"
            Command="{Binding ViewModel.ShowAboutPageCommand}">
            <StackPanel>
                <ui:TextBlock Text="About page" FontTypography="BodyStrong" />
                <ui:TextBlock
                    Text="Version, links and credits."
                    FontTypography="Caption"
                    TextWrapping="Wrap"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </ui:CardAction>

        <ui:TextBlock
            Margin="0 20 0 0"
            Text="Tools"
            FontTypography="BodyStrong" />
        <ui:TextBlock
            Margin="0 2 0 0"
            Text="Standalone tool pages."
            FontTypography="Caption"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        <ui:CardAction
            Margin="0 8 0 0"
            Icon="{ui:SymbolIcon LauncherSettings24}"
            Command="{Binding ViewModel.ShowRevitSettingsPageCommand}">
            <StackPanel>
                <ui:TextBlock Text="Revit settings page" FontTypography="BodyStrong" />
                <ui:TextBlock
                    Text="The Revit configuration editor."
                    FontTypography="Caption"
                    TextWrapping="Wrap"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </ui:CardAction>

    </StackPanel>

</Page>