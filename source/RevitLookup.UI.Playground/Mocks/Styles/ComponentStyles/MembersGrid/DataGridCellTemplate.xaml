<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:decomposition="clr-namespace:RevitLookup.Abstractions.ObservableModels.Decomposition;assembly=RevitLookup.Abstractions"
    xmlns:ui="http://lookupengine.com/xaml"
    xmlns:converters="clr-namespace:RevitLookup.UI.Framework.Converters;assembly=RevitLookup.UI.Framework"
    xmlns:views="clr-namespace:RevitLookup.UI.Framework.Views.Decomposition;assembly=RevitLookup.UI.Framework"
    xmlns:controls="clr-namespace:RevitLookup.UI.Framework.Controls;assembly=RevitLookup.UI.Framework"
    xmlns:mockConverters="clr-namespace:RevitLookup.UI.Playground.Mocks.Styles.Converters"
    mc:Ignorable="d">

    <DataTemplate
        x:Key="DefaultSummaryCellTemplate"
        DataType="{x:Type decomposition:ObservableDecomposedMember}">
        <ui:TextBlock
            VerticalAlignment="Center"
            FontTypography="Caption"
            FontWeight="{Binding FontWeight, 
                RelativeSource={RelativeSource FindAncestor, AncestorType=DataGridRow}}"
            Text="{Binding .,
                Converter={x:Static converters:DescriptorFormattingConverters.MemberDisplayText},
                Mode=OneTime}" />
    </DataTemplate>

    <DataTemplate
        x:Key="InvalidSummaryCellTemplate"
        DataType="{x:Type decomposition:ObservableDecomposedMember}">
        <controls:Chip
            Severity="Neutral"
            Outlined="True"
            Icon="CodeTextOff16"
            Text="Empty string"
            ToolTip="The member value is an empty string" />
    </DataTemplate>

    <DataTemplate
        x:Key="NullSummaryCellTemplate"
        DataType="{x:Type decomposition:ObservableDecomposedMember}">
        <controls:Chip
            Severity="Neutral"
            Outlined="True"
            Icon="CircleOff16"
            Text="Null reference"
            ToolTip="The member value is null" />
    </DataTemplate>

    <DataTemplate
        x:Key="SummaryMediaColorCellTemplate"
        DataType="{x:Type decomposition:ObservableDecomposedMember}">
        <StackPanel
            Orientation="Horizontal">
            <ui:TextBlock
                VerticalAlignment="Center"
                FontTypography="Caption"
                FontWeight="{Binding FontWeight, 
                    RelativeSource={RelativeSource FindAncestor, AncestorType=DataGridRow}}"
                Text="{Binding .,
                    Converter={x:Static converters:DescriptorFormattingConverters.MemberDisplayText},
                    Mode=OneTime}" />
            <Border
                CornerRadius="4"
                Padding="4 2"
                Margin="4 0 0 0"
                VerticalAlignment="Center"
                d:DataContext="{d:DesignInstance decomposition:ObservableDecomposedMember}">
                <Border.Background>
                    <SolidColorBrush
                        Opacity="0.05"
                        Color="{DynamicResource FocusStrokeColorOuter}" />
                </Border.Background>
                <Border
                    Width="10"
                    Height="10">
                    <Border.Background>
                        <SolidColorBrush
                            Color="{Binding Value.RawValue,
                            Converter={x:Static mockConverters:ColorConverters.MediaColor},
                            Mode=OneTime}" />
                    </Border.Background>
                </Border>
            </Border>
        </StackPanel>
    </DataTemplate>

    <DataTemplate
        x:Key="DeferredSummaryCellTemplate"
        DataType="{x:Type decomposition:ObservableDecomposedMember}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <controls:Chip
                Grid.Column="0"
                Severity="Info"
                Icon="Clock16"
                Text="Deferred" />
            <ui:Button
                x:Name="EvaluateButton"
                Grid.Column="1"
                Margin="8 0 0 0"
                Padding="6 2"
                VerticalAlignment="Center"
                Cursor="Hand"
                Appearance="Transparent"
                Visibility="Collapsed"
                Command="{Binding ViewModel.ForceEvaluateMemberCommand,
                    RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type views:SummaryViewBase}}}"
                CommandParameter="{Binding}">
                <StackPanel
                    Orientation="Horizontal">
                    <ui:SymbolIcon
                        FontSize="14"
                        Symbol="Calculator16"
                        VerticalAlignment="Center" />
                    <ui:TextBlock
                        Margin="4 0 0 0"
                        VerticalAlignment="Center"
                        FontTypography="Caption"
                        Text="Evaluate" />
                </StackPanel>
            </ui:Button>
        </Grid>
        <DataTemplate.Triggers>
            <DataTrigger
                Binding="{Binding IsMouseOver, RelativeSource={RelativeSource FindAncestor, AncestorType=DataGridRow}}"
                Value="True">
                <Setter
                    TargetName="EvaluateButton"
                    Property="Visibility"
                    Value="Visible" />
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <DataTemplate
        x:Key="DisabledSummaryCellTemplate"
        DataType="{x:Type decomposition:ObservableDecomposedMember}">
        <controls:Chip
            Severity="Caution"
            Icon="LockClosed16"
            Text="Disabled"
            ToolTip="Member evaluation permanently disabled" />
    </DataTemplate>

    <DataTemplate
        x:Key="UnsupportedSummaryCellTemplate"
        DataType="{x:Type decomposition:ObservableDecomposedMember}">
        <controls:Chip
            Severity="Neutral"
            Icon="Prohibited16"
            Text="Unsupported"
            ToolTip="Member evaluation not supported by the engine" />
    </DataTemplate>

    <DataTemplate
        x:Key="ExceptionSummaryCellTemplate"
        DataType="{x:Type decomposition:ObservableDecomposedMember}">
        <StackPanel
            Orientation="Horizontal"
            VerticalAlignment="Center">
            <controls:Chip
                Severity="Critical"
                Icon="ErrorCircle16"
                Text="Exception" />
            <ui:TextBlock
                Margin="8 0 0 0"
                VerticalAlignment="Center"
                FontTypography="Caption"
                TextTrimming="CharacterEllipsis"
                FontWeight="{Binding FontWeight,
                    RelativeSource={RelativeSource FindAncestor, AncestorType=DataGridRow}}"
                Text="{Binding .,
                    Converter={x:Static converters:DescriptorFormattingConverters.MemberDisplayText},
                    Mode=OneTime}" />
        </StackPanel>
    </DataTemplate>

</ResourceDictionary>