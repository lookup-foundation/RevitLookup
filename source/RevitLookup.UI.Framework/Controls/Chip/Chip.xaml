<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ui="http://lookupengine.com/xaml"
    xmlns:controls="clr-namespace:RevitLookup.UI.Framework.Controls"
    mc:Ignorable="d">

    <Style
        TargetType="{x:Type controls:Chip}">
        <Setter
            Property="Focusable"
            Value="False" />
        <Setter
            Property="HorizontalAlignment"
            Value="Left" />
        <Setter
            Property="VerticalAlignment"
            Value="Center" />
        <Setter
            Property="Padding"
            Value="6 2" />
        <Setter
            Property="Foreground"
            Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter
            Property="Background">
            <Setter.Value>
                <SolidColorBrush
                    Opacity="0.1"
                    Color="{DynamicResource TextFillColorPrimary}" />
            </Setter.Value>
        </Setter>
        <Setter
            Property="BorderThickness"
            Value="0" />
        <Setter
            Property="BorderBrush"
            Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
        <Setter
            Property="Template">
            <Setter.Value>
                <ControlTemplate
                    TargetType="{x:Type controls:Chip}">
                    <Border
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                        <StackPanel
                            Orientation="Horizontal">
                            <ui:SymbolIcon
                                x:Name="PART_Icon"
                                VerticalAlignment="Center"
                                FontSize="{TemplateBinding IconSize}"
                                Symbol="{TemplateBinding Icon}"
                                Foreground="{TemplateBinding Foreground}" />
                            <ui:TextBlock
                                x:Name="PART_Text"
                                Margin="4 0 0 0"
                                VerticalAlignment="Center"
                                FontTypography="Caption"
                                Text="{TemplateBinding Text}"
                                Foreground="{TemplateBinding Foreground}" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger
                            Property="Icon"
                            Value="Empty">
                            <Setter
                                TargetName="PART_Icon"
                                Property="Visibility"
                                Value="Collapsed" />
                            <Setter
                                TargetName="PART_Text"
                                Property="Margin"
                                Value="0" />
                        </Trigger>
                        <Trigger
                            Property="Text"
                            Value="">
                            <Setter
                                TargetName="PART_Text"
                                Property="Visibility"
                                Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger
                Property="Severity"
                Value="Info">
                <Setter
                    Property="Foreground"
                    Value="{DynamicResource SystemFillColorAttentionBrush}" />
                <Setter
                    Property="Background">
                    <Setter.Value>
                        <SolidColorBrush
                            Opacity="0.1"
                            Color="{DynamicResource SystemFillColorAttention}" />
                    </Setter.Value>
                </Setter>
            </Trigger>
            <Trigger
                Property="Severity"
                Value="Success">
                <Setter
                    Property="Foreground"
                    Value="{DynamicResource SystemFillColorSuccessBrush}" />
                <Setter
                    Property="Background">
                    <Setter.Value>
                        <SolidColorBrush
                            Opacity="0.12"
                            Color="{DynamicResource SystemFillColorSuccess}" />
                    </Setter.Value>
                </Setter>
            </Trigger>
            <Trigger
                Property="Severity"
                Value="Caution">
                <Setter
                    Property="Foreground"
                    Value="{DynamicResource SystemFillColorCautionBrush}" />
                <Setter
                    Property="Background">
                    <Setter.Value>
                        <SolidColorBrush
                            Opacity="0.12"
                            Color="{DynamicResource SystemFillColorCaution}" />
                    </Setter.Value>
                </Setter>
            </Trigger>
            <Trigger
                Property="Severity"
                Value="Critical">
                <Setter
                    Property="Foreground"
                    Value="{DynamicResource SystemFillColorCriticalBrush}" />
                <Setter
                    Property="Background">
                    <Setter.Value>
                        <SolidColorBrush
                            Opacity="0.12"
                            Color="{DynamicResource SystemFillColorCritical}" />
                    </Setter.Value>
                </Setter>
            </Trigger>
            <Trigger
                Property="Outlined"
                Value="True">
                <Setter
                    Property="Background"
                    Value="Transparent" />
                <Setter
                    Property="BorderThickness"
                    Value="1" />
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>